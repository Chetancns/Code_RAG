DB_HOST=localhost
DB_PORT=5432
DB_NAME=code_rag
DB_USER=postgres
DB_PASS=replace-with-your-password

# Optional profile presets: "balanced" (default) or "fast" for testing.
CHAT_PROFILE=fast

# Choose "openai" for ChatGPT or "ollama" for local Qwen3.
CHAT_PROVIDER=openai

# Shared chat timeout in milliseconds (fallback to OLLAMA_TIMEOUT_MS for compatibility).
CHAT_TIMEOUT_MS=30000

# Number of context chunks retrieved before answering.
RAG_RETRIEVAL_LIMIT=4

# OpenAI settings
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=250

# Ollama settings (used when CHAT_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_MS=900000
